<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Project List View -->
    <record id="view_jira_project_list" model="ir.ui.view">
        <field name="name">jira.project.list</field>
        <field name="model">jira.project</field>
        <field name="arch" type="xml">
            <list string="Projects" decoration-muted="state=='cancelled'"
                  decoration-success="state=='completed'">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="key"/>
                <field name="project_lead_id" widget="many2one_avatar_user"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state" widget="badge"
                       decoration-info="state=='draft'"
                       decoration-success="state=='active'"
                       decoration-warning="state=='on_hold'"
                       decoration-muted="state=='cancelled'"/>
                <field name="sprint_count"/>
                <field name="active_sprint_count"/>
                <field name="ticket_count"/>
            </list>
        </field>
    </record>
     <record model="ir.actions.act_window" id="action_jira_sprint_new">
         <field name="res_model">jira.sprint</field>
        <field name="view_mode">form</field>
        <field name="domain">[('project_id','=',active_id)]</field>
        <field name="context">{'default_project_id': active_id}</field>
    </record>
    <!-- Project Kanban View -->
    <record id="view_jira_project_kanban" model="ir.ui.view">
        <field name="name">jira.project.kanban</field>
        <field name="model">jira.project</field>
        <field name="arch" type="xml">
            <kanban highlight_color="color"
                class="o_hr_recruitment_kanban"

                sample="1"
                limit="40"
                action="%(action_jira_sprint)d"
                type="action">
                <field name="id"/>
                <field name="name"/>
                <field name="key"/>
                <field name="color"/>
                <field name="state"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="sprint_count"/>
                <field name="ticket_count"/>
                <field name="project_lead_id"/>

                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_color_#{kanban_getcolor(record.color.raw_value)} oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                        <div class="text-muted">
                                            <field name="key"/>
                                        </div>
                                    </div>
                                    <div class="o_dropdown_kanban dropdown">
                                        <a class="dropdown-toggle o-no-caret btn" role="button"
                                           data-bs-toggle="dropdown" href="#"
                                           aria-label="Dropdown menu" title="Dropdown menu">
                                            <span class="fa fa-ellipsis-v"/>
                                        </a>
                                        <div class="dropdown-menu" role="menu">
                                            <a role="menuitem" type="edit" class="dropdown-item">Edit</a>
                                            <a role="menuitem" type="delete" class="dropdown-item">Delete</a>
                                            <ul class="oe_kanban_colorpicker" data-field="color"/>
                                        </div>
                                    </div>
                                </div>


                                <div class="o_kanban_record_body">
                                    <div class="row mt-2">
                                        <div class="col-6">
                                            <i class="fa fa-calendar"/> <field name="start_date"/>
                                        </div>
                                        <div class="col-6">
                                            <i class="fa fa-calendar-check-o"/> <field name="end_date"/>
                                        </div>
                                    </div>

                                    <div class="row mt-2">
                                        <div class="col-6">
                                            <span class="badge badge-pill badge-info">
                                                <i class="fa fa-tasks"/> <field name="sprint_count"/> Sprints
                                            </span>
                                        </div>
                                        <div class="col-6">
                                            <span class="badge badge-pill badge-primary">
                                                <i class="fa fa-ticket"/> <field name="ticket_count"/> Tickets
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="project_lead_id" widget="many2one_avatar_user"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="state" widget="label_selection"
                                               options="{'classes': {'draft': 'secondary', 'active': 'success', 'on_hold': 'warning', 'completed': 'info', 'cancelled': 'danger'}}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Project Form View -->
    <record id="view_jira_project_form" model="ir.ui.view">
        <field name="name">jira.project.form</field>
        <field name="model">jira.project</field>
        <field name="arch" type="xml">
            <form string="Project">
                <header>
                    <button name="action_set_active" string="Set Active"
                            type="object" class="oe_highlight"
                            invisible="state == 'active'"/>
                    <button name="action_set_completed" string="Complete"
                            type="object" class="oe_highlight"
                            invisible="state == 'completed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                         <button class="oe_stat_button"
            type="action"
            name="%(action_jira_dashboard)d"
            icon="fa-dashboard">
        <div class="o_field_widget o_stat_info">
            <span class="o_stat_text">Dashboard</span>
        </div>
    </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_sprints" icon="fa-tasks">
                            <field string="Sprints" name="sprint_count" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_tickets" icon="fa-ticket">
                            <field string="Tickets" name="ticket_count" widget="statinfo"/>
                        </button>
                    </div>
                    <field name="avatar_128" widget="image" class="oe_avatar"
                           options="{'size': [90, 90]}"/>
                    <div class="oe_title">
                        <label for="name" string="Project Name"/>
                        <h1>
                            <field name="name" placeholder="e.g., Website Redesign"/>
                        </h1>
                        <h2>
                            <field name="key" placeholder="e.g., WEB" class="oe_inline"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="project_lead_id" widget="many2one_avatar_user"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Project description and goals..."/>
                        </page>
                        <page string="Team" name="team">
                            <field name="team_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                        </page>
                        <page string="Workflow States" name="workflow">
                            <field name="workflow_state_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="is_default"/>
                                    <field name="is_closed"/>
                                    <field name="fold"/>
                                    <field name="color" widget="color_picker"/>
                                </list>
                            </field>
                        </page>
                        <page string="Sprints" name="sprints">
                            <field name="sprint_ids">
                                <list decoration-bf="state=='active'">
                                    <field name="name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="ticket_count"/>
                                    <field name="progress" widget="progressbar"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Project Search View -->
    <record id="view_jira_project_search" model="ir.ui.view">
        <field name="name">jira.project.search</field>
        <field name="model">jira.project</field>
        <field name="arch" type="xml">
            <search string="Projects">
                <field name="name"/>
                <field name="key"/>
                <field name="project_lead_id"/>
                <filter string="My Projects" name="my_projects"
                        domain="[('project_lead_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="status" context="{'group_by': 'state'}"/>
                    <filter string="Project Lead" name="lead" context="{'group_by': 'project_lead_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Project Action -->
    <record id="action_jira_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">jira.project</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first project
            </p>
            <p>
                Projects help you organize your work into manageable pieces.
            </p>
        </field>
    </record>
</odoo>