<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_jira_weekly_report" model="ir.cron">
        <field name="name">Jira PM — Send Weekly Reports</field>
        <field name="model_id" ref="model_jira_report"/>
        <field name="state">code</field>
        <field name="code">
            model._cron_send_weekly_reports()
        </field>
        <field name="interval_number">1</field>
        <field name="interval_type">weeks</field>
        <field name="active">True</field>
    </record>
</odoo>