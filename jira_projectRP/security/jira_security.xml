<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">


        <record id="module_jira_project" model="ir.module.category">
            <field name="name">Jira Project Management</field>
            <field name="description">User access levels for Jira-style project management</field>
            <field name="sequence">10</field>
        </record>



        <record id="group_jira_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_jira_project"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">
                User can:
                - View all projects, sprints, and tickets
                - Create and edit tickets assigned to them
                - Update ticket status
                - Add comments and attachments
                - Track time
            </field>
        </record>



        <record id="group_jira_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_jira_project"/>
            <field name="implied_ids" eval="[(4, ref('group_jira_user'))]"/>
            <field name="comment">
                Manager can:
                - Everything that User can do
                - Create/Edit/Delete projects
                - Create/Edit/Delete sprints
                - Configure workflow states
                - Manage team members
                - Delete tickets
                - View reports and analytics
            </field>
        </record>



        <!-- Rule: Users can only edit tickets assigned to them -->
        <record id="jira_ticket_user_rule" model="ir.rule">
            <field name="name">Jira Ticket: User can edit own tickets</field>
            <field name="model_id" ref="model_jira_ticket"/>
            <field name="domain_force">[
                '|',
                    ('assignee_id', '=', user.id),
                    ('reporter_id', '=', user.id)
            ]</field>
            <field name="groups" eval="[(4, ref('group_jira_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Rule: Managers can access all tickets -->
        <record id="jira_ticket_manager_rule" model="ir.rule">
            <field name="name">Jira Ticket: Manager can access all</field>
            <field name="model_id" ref="model_jira_ticket"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_jira_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Rule: Users can see all projects (read-only unless manager) -->
        <record id="jira_project_user_rule" model="ir.rule">
            <field name="name">Jira Project: User can view all</field>
            <field name="model_id" ref="model_jira_project"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_jira_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Rule: Users can see all sprints (read-only unless manager) -->
        <record id="jira_sprint_user_rule" model="ir.rule">
            <field name="name">Jira Sprint: User can view all</field>
            <field name="model_id" ref="model_jira_sprint"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_jira_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>