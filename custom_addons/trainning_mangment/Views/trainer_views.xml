<odoo>

<!--vue liste-->

    <record id="training_trainer_tree_view" model="ir.ui.view">
        <field name="name">trainers.tree</field>
        <field name="model">training.trainer</field>
        <field name="arch" type="xml">
        <list>
            <field name="name"/>
            <field name="age"/>
            <field name="date_Naisse"/>
            <field name="active"/>
        </list>
        </field>
    </record>
    <!--vue formullaire-->
    <record id="training_trainer_form_view" model="ir.ui.view">
        <field name="name">trainers.form</field>
        <field name="model">training.trainer</field>
        <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="age"/>
                    <field name="date_Naisse"/>
                </group>
            </sheet>
        </form>
        </field>
    </record>
    <record id="action_training_trainer" model="ir.actions.act_window">
        <field name="name">training</field>
        <field name="res_model">training.trainer</field>
        <field name="view_mode">list,form</field>

    </record>
        <!--menu principale training-->
    <menuitem id="menu_training_root" name="training" sequence="10"/>
    <menuitem id="menu_training_trainer" name="trainers" parent="menu_training_root" action="trainning_mangment.action_training_trainer"/>

</odoo>