<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Séquence pour les tickets -->
        <record id="seq_project_ticket" model="ir.sequence">
            <field name="name">Project Ticket Sequence</field>
            <field name="code">project.ticket</field>
            <field name="prefix"></field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>

        <!-- Séquence pour les sprints -->
        <record id="seq_project_sprint" model="ir.sequence">
            <field name="name">Project Sprint Sequence</field>
            <field name="code">project.sprint</field>
            <field name="prefix"></field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>

    </data>
</odoo>