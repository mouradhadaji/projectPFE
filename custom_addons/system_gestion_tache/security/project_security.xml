<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Catégorie du module -->
        <record id="module_category_project_management" model="ir.module.category">
            <field name="name">Project Management</field>
            <field name="sequence">10</field>
        </record>

        <!-- Groupe User -->
        <record id="group_project_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_project_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Groupe Manager -->
        <record id="group_project_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_project_management"/>
            <field name="implied_ids" eval="[(4, ref('group_project_user'))]"/>
        </record>

        <!-- Règles d'accès -->
        <record id="rule_project_management_all" model="ir.rule">
            <field name="name">All Projects</field>
            <field name="model_id" ref="model_project_management"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_project_sprint_all" model="ir.rule">
            <field name="name">All Sprints</field>
            <field name="model_id" ref="model_project_sprint"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_project_ticket_all" model="ir.rule">
            <field name="name">All Tickets</field>
            <field name="model_id" ref="model_project_ticket"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

    </data>
</odoo>