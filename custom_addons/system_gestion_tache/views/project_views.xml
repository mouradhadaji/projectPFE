<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue Formulaire Projet -->
    <record id="view_project_management_form" model="ir.ui.view">
        <field name="name">project.management.form</field>
        <field name="model">project.management</field>
        <field name="arch" type="xml">
            <form string="Projet">
                <header>
                    <button name="action_view_tickets"
                            type="object"
                            string="Voir les Tickets"
                            class="oe_highlight"
                            icon="fa-tasks"/>
                    <field name="state" widget="statusbar"
                           options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_tickets"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-ticket">
                            <field name="ticket_count" widget="statbutton" string="Tickets"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom du projet..."/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="key" placeholder="Ex: PROJ"/>
                            <field name="methodology"/>
                        </group>
                        <group>
                            <field name="team_member_ids" widget="many2many_tags"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Description du projet..."/>
                        </page>
                        <page string="Sprints">
                            <field name="sprint_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="state"/>
                                    <field name="ticket_count"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vue Liste Projet -->
    <record id="view_project_management_tree" model="ir.ui.view">
        <field name="name">project.management.tree</field>
        <field name="model">project.management</field>
        <field name="arch" type="xml">
            <list string="Projets">
                <field name="name"/>
                <field name="key"/>
                <field name="methodology"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-info="state == 'draft'"
                       decoration-muted="state == 'completed'"/>
                <field name="ticket_count"/>
            </list>
        </field>
    </record>

    <!-- Action Projet -->
    <record id="action_project_management" model="ir.actions.act_window">
        <field name="name">Projets</field>
        <field name="res_model">project.management</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>