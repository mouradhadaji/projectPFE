<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue Formulaire Sprint -->
    <record id="view_project_sprint_form" model="ir.ui.view">
        <field name="name">project.sprint.form</field>
        <field name="model">project.sprint</field>
        <field name="arch" type="xml">
            <form string="Sprint">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_tickets" icon="fa-tasks">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="ticket_count"/>
                                </span>
                                <span class="o_stat_text">Tickets</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Sprint 1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="start_date"/>
                        </group>
                        <group>
                            <field name="end_date"/>
                        </group>
                    </group>

                    <group string="Objectif du Sprint">
                        <field name="goal" nolabel="1" placeholder="Quel est l'objectif de ce sprint?"/>
                    </group>

                    <notebook>
                        <page string="Tickets">
                            <field name="ticket_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="title"/>
                                    <field name="state"/>
                                    <field name="assigned_to"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vue Liste Sprint -->
    <record id="view_project_sprint_list" model="ir.ui.view">
        <field name="name">project.sprint.list</field>
        <field name="model">project.sprint</field>
        <field name="arch" type="xml">
            <list string="Sprints">
                <field name="name"/>
                <field name="project_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
                <field name="ticket_count"/>
            </list>
        </field>
    </record>

    <!-- Action Sprint -->
    <record id="action_project_sprint" model="ir.actions.act_window">
        <field name="name">Sprints</field>
        <field name="res_model">project.sprint</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>