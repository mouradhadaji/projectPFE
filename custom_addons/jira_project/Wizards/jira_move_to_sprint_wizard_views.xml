<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_jira_move_to_sprint_wizard" model="ir.ui.view">
        <field name="name">jira.move.to.sprint.wizard.form</field>
        <field name="model">jira.move.to.sprint.wizard</field>
        <field name="arch" type="xml">
            <form string="Move to Sprint">
                <sheet>
                    <div style="padding: 8px 0 16px;">
                        <h3 style="margin: 0; font-size: 16px; font-weight: 600;
                                   color: #1a1a2e;">
                            Move ticket to sprint
                        </h3>
                    </div>
                    <group>
                        <field name="ticket_id" readonly="1"/>
                        <field name="project_id" readonly="1"/>
                        <field name="sprint_id"
                               options="{'no_create': True}"
                               placeholder="Select a sprint..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_move"
                            string="Move to Sprint"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_jira_move_to_sprint_wizard" model="ir.actions.act_window">
        <field name="name">Move to Sprint</field>
        <field name="res_model">jira.move.to.sprint.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{}</field>
    </record>
</odoo>