<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_jira_ticket" model="ir.sequence">
            <field name="name">Jira Ticket Sequence</field>
            <field name="code">jira.ticket.sequence</field>
            <field name="prefix"></field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>


        <record id="label_bug" model="jira.label">
            <field name="name">Bug</field>
            <field name="color">1</field>
        </record>

        <record id="label_enhancement" model="jira.label">
            <field name="name">Enhancement</field>
            <field name="color">3</field>
        </record>

        <record id="label_documentation" model="jira.label">
            <field name="name">Documentation</field>
            <field name="color">5</field>
        </record>

        <record id="label_urgent" model="jira.label">
            <field name="name">Urgent</field>
            <field name="color">2</field>
        </record>

        <record id="label_technical_debt" model="jira.label">
            <field name="name">Technical Debt</field>
            <field name="color">7</field>
        </record>
    </data>
</odoo>