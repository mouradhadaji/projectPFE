<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sprint List View -->
    <record id="view_jira_sprint_list" model="ir.ui.view">
        <field name="name">jira.sprint.list</field>
        <field name="model">jira.sprint</field>
        <field name="arch" type="xml">
            <list string="Sprints" decoration-bf="state=='active'"
                  decoration-muted="state in ['completed', 'cancelled']">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="duration_days"/>
                <field name="ticket_count"/>
                <field name="progress" widget="progressbar"/>
                <field name="total_story_points"/>
                <field name="completed_story_points"/>
                <field name="state" widget="badge"
                       decoration-info="state=='draft'"
                       decoration-success="state=='active'"
                       decoration-muted="state in ['completed', 'cancelled']"/>
            </list>
        </field>
    </record>
<!-- Sprint Kanban View -->
<record id="view_jira_sprint_kanban" model="ir.ui.view">
    <field name="name">jira.sprint.kanban</field>
    <field name="model">jira.sprint</field>
    <field name="arch" type="xml">
      <kanban create="true" edit="true" delete="true"

        class="o_kanban_dashboard o_kanban_small_column o_sprint_kanban"
        action="%(action_jira_ticket_from_sprint)d"
        type="action"
        sample="1">

            <field name="id"/>
            <field name="name"/>
            <field name="project_id"/>
            <field name="state"/>
            <field name="start_date"/>
            <field name="end_date"/>
            <field name="ticket_count"/>
            <field name="completed_ticket_count"/>
            <field name="progress"/>
            <field name="color"/>
            <field name="total_story_points"/>
            <field name="completed_story_points"/>
            <field name="duration_days"/>

           <templates>


                <!-- ✅ UN SEUL kanban-menu ICI, INSIDE templates -->
                <t t-name="kanban-menu">
                    <a role="menuitem" type="edit" class="dropdown-item">
                        <i class="fa fa-pencil me-2"/> Modifier
                    </a>
                    <a role="menuitem" type="delete" class="dropdown-item text-danger">
                        <i class="fa fa-trash me-2"/> Supprimer
                    </a>
                    <a role="menuitem" type="open" class="dropdown-item">
                        <i class="fa fa-external-link me-2"/> Ouvrir
                    </a>
                </t>

               <t t-name="kanban-box">
    <t t-set="card_color" t-value="record.state.raw_value == 'active' ? '#28a745' : record.state.raw_value == 'completed' ? '#17a2b8' : record.state.raw_value == 'cancelled' ? '#dc3545' : '#6c757d'"/>

    <div t-attf-style="
        min-height: 200px;
        width: 350px;
        border-radius: 12px;
        border: 1px solid #dee2e6;
        border-left: 6px solid #{card_color};
        display: flex;
        flex-direction: column;
        background-color:white;
        padding: 16px;">


        <!-- HEADER coloré -->
              <div style="background-color: #6C9EEB; margin: -16px -16px 12px -16px; padding: 16px;">
           <h3 style="font-weight: 600; font-size: 18px; margin: 0 0 4px 0; color: white;">
        <field name="name"/>
              </h3>
              <div style="color: #B5D4F4; font-size: 13px;">
        <i class="fa fa-folder-o"/> <field name="project_id"/>
               </div>
               </div>
        <!-- Séparateur -->
        <div style="border-top: 1px solid #f0f0f0; margin-bottom: 12px;"/>

        <!-- Dates -->
        <div style="display: flex; gap: 16px; margin-bottom: 12px;">
            <div>
                <div style="font-size: 11px; color: #6c757d;">Start</div>
                <div style="font-size: 13px; font-weight: 500;"><field name="start_date"/></div>
            </div>
            <div>
                <div style="font-size: 11px; color: #6c757d;">End</div>
                <div style="font-size: 13px; font-weight: 500;"><field name="end_date"/></div>
            </div>
        </div>

        <!-- Progress -->
        <div style="margin-bottom: 12px;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                <small style="color: #6c757d;">Progress</small>
                <small style="color: #6c757d;">
                    <field name="completed_ticket_count"/>/<field name="ticket_count"/> tickets
                </small>
            </div>
            <field name="progress" widget="progressbar"/>
        </div>

        <!-- Stats -->
        <div style="display: flex; gap: 20px; margin-bottom: 12px;">
            <div style="display: flex; align-items: center; gap: 6px;">
                <i class="fa fa-ticket" style="color: #6c757d;"/>
                <span style="font-size: 20px; font-weight: 600;"><field name="ticket_count"/></span>
                <small style="color: #6c757d;">Tickets</small>
            </div>
            <div style="display: flex; align-items: center; gap: 6px;">
                <i class="fa fa-line-chart" style="color: #28a745;"/>
                <span style="font-size: 20px; font-weight: 600;"><field name="total_story_points"/></span>
                <small style="color: #6c757d;">Story Points</small>
            </div>
        </div>

        <!-- Footer -->
        <div style="background-color: #6C9EEB; margin: 12px -16px -16px -16px; padding: 12px 16px; display: flex; justify-content: space-between; align-items: center;">
    <span style="padding: 4px 12px; border-radius: 12px; font-size: 11px; color: #185FA5; background: white;">
        <field name="state"/>
    </span>
    <span style="font-size: 11px; color: white;">
        <i class="fa fa-clock-o"/> <field name="duration_days"/> days
    </span>
</div>
    </div>
</t>
            </templates>
        </kanban>
    </field>
</record>

    <!-- Sprint Form View -->
    <record id="view_jira_sprint_form" model="ir.ui.view">
        <field name="name">jira.sprint.form</field>
        <field name="model">jira.sprint</field>
        <field name="arch" type="xml">
            <form string="Sprint">
                <header>
                    <button name="action_start_sprint" string="Start Sprint"
                            type="object" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_complete_sprint" string="Complete Sprint"
                            type="object" class="oe_highlight"
                            invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                <button class="oe_stat_button" type="action"
        name="%(action_jira_ticket_from_sprint)d" icon="fa-ticket"
        context="{'default_sprint_id': id, 'search_default_sprint_id': id}">
    <div class="o_field_widget o_stat_info">
        <span class="o_stat_value">
            <field name="completed_ticket_count"/>/<field name="ticket_count"/>
        </span>
        <span class="o_stat_text">Tickets</span>
    </div>
</button>
<button class="oe_stat_button" type="action"
        name="%(action_jira_ticket_from_sprint)d" icon="fa-line-chart"
        context="{'default_sprint_id': id, 'search_default_sprint_id': id}">
    <div class="o_field_widget o_stat_info">
        <span class="o_stat_value">
            <field name="completed_story_points" widget="float"/>/<field name="total_story_points" widget="float"/>
        </span>
        <span class="o_stat_text">Story Points</span>
    </div>
</button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Sprint Name"/>
                        <h1>
                            <field name="name" placeholder="e.g., Sprint 1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" options="{'no_create': True}"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="duration_days"/>
                        </group>
                        <group>
                            <field name="progress" widget="progressbar"/>
                            <field name="sequence"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                    </group>
                    <group string="Sprint Goal">
                        <field name="goal" nolabel="1" placeholder="What is the goal of this sprint?"/>
                    </group>
                    <notebook>
                        <page string="Workflow States" name="workflow">
                            <field name="workflow_state_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"
                                   domain="[('project_id', '=', project_id)]"/>
                        </page>
                        <page string="Tickets" name="tickets">
                            <field name="ticket_ids">
                                <list decoration-muted="state_id.is_closed">
                                    <field name="ticket_number"/>
                                    <field name="name"/>
                                    <field name="ticket_type" widget="badge"/>
                                    <field name="priority" widget="priority"/>
                                    <field name="assignee_id" widget="many2one_avatar_user"/>
                                    <field name="state_id"/>
                                    <field name="story_points"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Sprint Search View -->
    <record id="view_jira_sprint_search" model="ir.ui.view">
        <field name="name">jira.sprint.search</field>
        <field name="model">jira.sprint</field>
        <field name="arch" type="xml">
            <search string="Sprints">
                <field name="name"/>
                <field name="project_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="project" context="{'group_by': 'project_id'}"/>
                    <filter string="Status" name="status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>


<!-- Sprint Action -->
<record id="action_jira_sprint" model="ir.actions.act_window">
    <field name="name">Sprints</field>
    <field name="res_model">jira.sprint</field>
    <field name="view_mode">kanban,list,form</field>
    <field name="domain">[]</field>
    <field name="context">{

        'kanban_view_ref': 'jira_project.view_jira_sprint_kanban'
    }</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            Create your first sprint
        </p>
        <p>
            Sprints are time-boxed periods where teams complete work.
        </p>
    </field>
</record>


    <!-- Active Sprints Action -->
    <record id="action_jira_sprint_active" model="ir.actions.act_window">
        <field name="name">Active Sprints</field>
        <field name="res_model">jira.sprint</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{}</field>
    </record>
</odoo>