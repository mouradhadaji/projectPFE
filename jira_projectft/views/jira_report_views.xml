<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_jira_report_form" model="ir.ui.view">
        <field name="name">jira.report.form</field>
        <field name="model">jira.report</field>
        <field name="arch" type="xml">
            <form string="Report Schedule">
                <header>
                    <button name="action_send_report"
                            string="Send Now"
                            type="object"
                            class="oe_highlight"
                            icon="fa-paper-plane"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Report Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="sprint_id"
                                   domain="[('project_id', '=', project_id)]"/>
                            <field name="frequency"/>
                        </group>
                        <group>
                            <field name="include_tickets"/>
                            <field name="include_sprint"/>
                            <field name="last_sent" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Recipients">
                        <field name="recipient_ids"
                               widget="many2many_tags"
                               nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_jira_report_list" model="ir.ui.view">
        <field name="name">jira.report.list</field>
        <field name="model">jira.report</field>
        <field name="arch" type="xml">
            <list string="Reports">
                <field name="name"/>
                <field name="project_id"/>
                <field name="frequency"/>
                <field name="last_sent"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_jira_report" model="ir.actions.act_window">
        <field name="name">Reports</field>
        <field name="res_model">jira.report</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>