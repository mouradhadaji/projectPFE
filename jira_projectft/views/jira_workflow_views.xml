<?xml version="1.0" encoding="utf-8"?>
<odoo>



    <record id="view_jira_workflow_state_list" model="ir.ui.view">
        <field name="name">jira.workflow.state.list</field>
        <field name="model">jira.workflow.state</field>
        <field name="arch" type="xml">
            <list string="Workflow States"
                  editable="bottom"
                  decoration-success="is_closed==True"
                  decoration-primary="is_default==True">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="category"/>
                <field name="is_default"/>
                <field name="is_closed"/>
                <field name="fold"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>



    <record id="view_jira_workflow_state_form" model="ir.ui.view">
        <field name="name">jira.workflow.state.form</field>
        <field name="model">jira.workflow.state</field>
        <field name="arch" type="xml">
            <form string="Workflow State">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="State Name"/>
                        <h1>
                            <field name="name" placeholder="e.g., To Do, In Progress, Done..."/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="project_id" options="{'no_create': True}"/>
                            <field name="category"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="is_default"/>
                            <field name="is_closed"/>
                            <field name="fold"/>
                        </group>
                    </group>

                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="What does this state mean?"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>



    <record id="view_jira_workflow_state_search" model="ir.ui.view">
        <field name="name">jira.workflow.state.search</field>
        <field name="model">jira.workflow.state</field>
        <field name="arch" type="xml">
            <search string="Workflow States">
                <field name="name"/>
                <field name="project_id"/>
                <filter string="Default State" name="default"
                        domain="[('is_default', '=', True)]"/>
                <filter string="Closed States" name="closed"
                        domain="[('is_closed', '=', True)]"/>
                <separator/>
                <filter string="To Do" name="todo"
                        domain="[('category', '=', 'todo')]"/>
                <filter string="In Progress" name="in_progress"
                        domain="[('category', '=', 'in_progress')]"/>
                <filter string="Done" name="done"
                        domain="[('category', '=', 'done')]"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="project"
                            context="{'group_by': 'project_id'}"/>
                    <filter string="Category" name="category"
                            context="{'group_by': 'category'}"/>
                </group>
            </search>
        </field>
    </record>



    <record id="action_jira_workflow_state" model="ir.actions.act_window">
        <field name="name">Workflow States</field>
        <field name="res_model">jira.workflow.state</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first workflow state
            </p>
            <p>
                Workflow states define the lifecycle of tickets.<br/>
                Examples: To Do, In Progress, Code Review, Testing, Done
            </p>
        </field>
    </record>

</odoo>