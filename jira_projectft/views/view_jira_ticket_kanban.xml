<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ticket Kanban View with Drag & Drop -->
    <record id="view_jira_ticket_kanban" model="ir.ui.view">
        <field name="name">jira.ticket.kanban</field>
        <field name="model">jira.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state_id"
                    on_create="quick_create"
                    quick_create_view="jira_project.view_jira_ticket_form"
                    class="o_kanban_small_column"
                    sample="1">

                <field name="id"/>
                <field name="ticket_number"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="sprint_id"/>
                <field name="ticket_type"/>
                <field name="priority"/>
                <field name="assignee_id"/>
                <field name="state_id"/>
                <field name="story_points"/>
                <field name="due_date"/>
                <field name="is_overdue"/>
                <field name="color"/>
                <field name="kanban_state"/>
                <field name="label_ids"/>
                <field name="subtask_count"/>

                <progressbar field="kanban_state"
                            colors='{"done": "success", "blocked": "danger", "normal": "muted"}'/>

                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click #{record.is_overdue.raw_value ? 'oe_kanban_card_danger' : ''}">
                            <div class="oe_kanban_content">

                                <!-- Header: Ticket Number & Priority -->
                                <div class="o_kanban_record_top mb-2">
                                    <div class="o_kanban_record_headings">
                                        <strong>
                                            <field name="ticket_number"/>
                                        </strong>
                                    </div>
                                    <div>
                                        <field name="priority" widget="priority"/>
                                    </div>
                                </div>

                                <!-- Title -->
                                <div class="o_kanban_record_title mb-2">
                                    <strong><field name="name"/></strong>
                                </div>

                                <!-- Ticket Type Badge -->
                                <div class="mb-2">
                                    <field name="ticket_type" widget="badge"
                                           decoration-info="ticket_type=='story'"
                                           decoration-success="ticket_type=='task'"
                                           decoration-danger="ticket_type=='bug'"
                                           decoration-warning="ticket_type=='epic'"
                                           decoration-secondary="ticket_type=='subtask'"/>
                                </div>

                                <!-- Labels -->
                                <div class="mb-2" t-if="record.label_ids.raw_value.length">
                                    <field name="label_ids" widget="many2many_tags"
                                           options="{'color_field': 'color'}"/>
                                </div>

                                <!-- Story Points & Due Date -->
                                <div class="o_kanban_record_body mb-2">
                                    <span t-if="record.story_points.raw_value"
                                          class="badge badge-pill badge-primary">
                                        <i class="fa fa-chart-line"/>
                                        <field name="story_points"/> pts
                                    </span>

                                    <span t-if="record.due_date.raw_value"
                                          t-attf-class="badge badge-pill #{record.is_overdue.raw_value ? 'badge-danger' : 'badge-secondary'}">
                                        <i class="fa fa-calendar"/>
                                        <field name="due_date"/>
                                    </span>

                                    <span t-if="record.subtask_count.raw_value > 0"
                                          class="badge badge-pill badge-info">
                                        <i class="fa fa-tasks"/>
                                        <field name="subtask_count"/>
                                    </span>
                                </div>

                                <!-- Footer: Assignee & Project -->
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="assignee_id" widget="many2one_avatar_user"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="kanban_state" widget="state_selection"/>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Kanban Board Action -->
    <record id="action_jira_ticket_kanban" model="ir.actions.act_window">
        <field name="name">Kanban Board</field>
        <field name="res_model">jira.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{
            'search_default_project_id': active_id if active_model == 'jira.project' else False,
            'search_default_sprint_id': active_id if active_model == 'jira.sprint' else False,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Your Kanban board is empty
            </p>
            <p>
                Drag and drop tickets between columns to update their status.
            </p>
        </field>
    </record>

</odoo>