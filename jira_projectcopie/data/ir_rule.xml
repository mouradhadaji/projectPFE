<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Manager voit seulement ses projets assignés -->
    <record id="rule_project_manager" model="ir.rule">
        <field name="name">Manager sees assigned projects only</field>
        <field name="model_id" ref="model_jira_project"/>
        <field name="groups" eval="[(4, ref('jira_project.group_jira_manager'))]"/>
        <field name="domain_force">
            [('manager_id', '=', user.id)]
        </field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Manager voit seulement les sprints de ses projets -->
    <record id="rule_sprint_manager" model="ir.rule">
        <field name="name">Manager sees sprints of assigned projects only</field>
        <field name="model_id" ref="model_jira_sprint"/>
        <field name="groups" eval="[(4, ref('jira_project.group_jira_manager'))]"/>
        <field name="domain_force">
            [('project_id.manager_id', '=', user.id)]
        </field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Manager voit seulement les tickets de ses projets -->
    <record id="rule_ticket_manager" model="ir.rule">
        <field name="name">Manager sees tickets of assigned projects only</field>
        <field name="model_id" ref="model_jira_ticket"/>
        <field name="groups" eval="[(4, ref('jira_project.group_jira_manager'))]"/>
        <field name="domain_force">
            [('project_id.manager_id', '=', user.id)]
        </field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Director voit tout — pas de restriction -->
    <record id="rule_project_director" model="ir.rule">
        <field name="name">Director sees all projects</field>
        <field name="model_id" ref="model_jira_project"/>
        <field name="groups" eval="[(4, ref('jira_project.group_jira_director'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>