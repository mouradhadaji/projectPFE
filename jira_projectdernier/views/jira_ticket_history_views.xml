<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue List -->
    <record id="view_jira_ticket_history_list" model="ir.ui.view">
        <field name="name">jira.ticket.history.list</field>
        <field name="model">jira.ticket.history</field>
        <field name="arch" type="xml">
            <list string="Historique des statuts" default_order="change_date desc">
                <field name="ticket_id" string="Ticket"/>
                <field name="project_id" string="Projet"/>
                <field name="old_status" string="Ancien statut"/>
                <field name="new_status" string="Nouveau statut"
                       decoration-success="new_status in ('done','complete')"
                       decoration-info="new_status == 'in_progress'"
                       decoration-warning="new_status == 'in_review'"
                       decoration-danger="new_status == 'blocked'"/>
                <field name="change_date" string="Date"/>
                <field name="user_id" string="Modifié par"/>
            </list>
        </field>
    </record>

    <!-- Vue Search -->
    <record id="view_jira_ticket_history_search" model="ir.ui.view">
        <field name="name">jira.ticket.history.search</field>
        <field name="model">jira.ticket.history</field>
        <field name="arch" type="xml">
            <search string="Rechercher">
                <field name="ticket_id" string="Ticket"/>
                <field name="project_id" string="Projet"/>
                <field name="new_status" string="Statut"/>
                <filter string="Done" name="done"
                        domain="[('new_status','in',['done','complete'])]"/>
                <filter string="In Progress" name="in_progress"
                        domain="[('new_status','=','in_progress')]"/>
                <filter string="Blocked" name="blocked"
                        domain="[('new_status','=','blocked')]"/>
                <group expand="0" string="Grouper par">
                    <filter string="Projet" name="group_project"
                            context="{'group_by':'project_id'}"/>
                    <filter string="Statut" name="group_status"
                            context="{'group_by':'new_status'}"/>
                    <filter string="Semaine" name="group_week"
                            context="{'group_by':'change_date:week'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_jira_ticket_history" model="ir.actions.act_window">
        <field name="name">Historique des tickets</field>
        <field name="res_model">jira.ticket.history</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_jira_ticket_history_search"/>
        <field name="context">{}</field>
    </record>

    <!-- Menu item -->
    <menuitem id="menu_jira_ticket_history"
              name="Historique des tickets"
              parent="menu_jira_root"
              action="action_jira_ticket_history"
              sequence="30"/>

</odoo>