<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_jira_sprint_planning_form" model="ir.ui.view">
        <field name="name">jira.sprint.planning.form</field>
        <field name="model">jira.sprint</field>
        <field name="arch" type="xml">
            <form string="Sprint Planning">
                <header>
                    <button name="action_start_sprint"
                            string="▶ Démarrer le Sprint"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_complete_sprint"
                            string="✅ Terminer le Sprint"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,completed"/>
                </header>
                <sheet>

                    <!-- Header Sprint -->
                    <div style="background: linear-gradient(135deg, #1E3A5F 0%, #2563EB 100%);
                                padding: 20px 28px; border-radius: 10px; margin-bottom: 20px;">
                        <div style="display:flex; justify-content:space-between; align-items:center;">
                            <div>
                                <h2 style="color:white; margin:0; font-size:18px; font-weight:700;">
                                    🏃 Sprint Planning
                                </h2>
                                <p style="color:rgba(255,255,255,0.85); margin:4px 0 0; font-size:12px;">
                                    Glissez les tâches du backlog dans ce sprint
                                </p>
                            </div>
                            <!-- Capacité -->
                            <div style="display:flex; gap:16px;">
                                <div style="background:rgba(255,255,255,0.15); border-radius:8px;
                                            padding:10px 16px; text-align:center;">
                                    <div style="font-size:22px; font-weight:700; color:white;">
                                        <field name="total_story_points" readonly="1"/>
                                    </div>
                                    <div style="font-size:10px; color:rgba(255,255,255,0.8);">
                                        Story Points
                                    </div>
                                </div>
                                <div style="background:rgba(255,255,255,0.15); border-radius:8px;
                                            padding:10px 16px; text-align:center;">
                                    <div style="font-size:22px; font-weight:700; color:white;">
                                        <field name="ticket_count" readonly="1"/>
                                    </div>
                                    <div style="font-size:10px; color:rgba(255,255,255,0.8);">
                                        Tâches
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Infos Sprint -->
                    <group>
                        <group>
                            <field name="name" placeholder="Nom du sprint..."/>
                            <field name="project_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="goal" placeholder="Objectif du sprint..."/>
                        </group>
                    </group>

                    <!-- Section tâches du sprint -->
                    <div style="border-radius:10px; border:1px solid #2563EB; overflow:hidden; margin-bottom:20px;">
                        <div style="background:linear-gradient(135deg,#1E4DB7 0%,#2563EB 100%);
                                    padding:14px 20px; display:flex;
                                    justify-content:space-between; align-items:center;">
                            <div style="display:flex; align-items:center; gap:10px;">
                                <i class="fa fa-tasks" style="color:white;"/>
                                <span style="font-size:14px; font-weight:700; color:white;">
                                    📋 Tâches du Sprint
                                </span>
                                <span style="background:rgba(255,255,255,0.25); color:white;
                                             font-size:11px; padding:2px 10px;
                                             border-radius:999px; font-weight:600;">
                                    <field name="ticket_count" readonly="1"/> tâches
                                    /
                                    <field name="total_story_points" readonly="1"/> pts
                                </span>
                            </div>
                        </div>
                        <div style="background:white; padding:16px;">
                            <field name="ticket_ids" nolabel="1">
                                <list editable="bottom"
                                      default_order="priority desc, sequence"
                                      decoration-danger="priority == '3'"
                                      decoration-warning="priority == '2'"
                                      decoration-muted="ticket_status == 'complete'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name" string="Tâche"/>
                                    <field name="ticket_type" widget="badge" string="Type"/>
                                    <field name="priority" widget="priority" string="Priorité"/>
                                    <field name="story_points" string="Points"
                                           sum="Total Points"/>
                                    <field name="assignee_id"
                                           widget="many2one_avatar_user"
                                           string="Assigné"/>
                                    <field name="ticket_status" widget="badge" string="Statut"
                                           decoration-success="ticket_status == 'complete'"
                                           decoration-warning="ticket_status == 'in_progress'"/>
                                    <button name="action_remove_from_sprint"
                                            string="← Backlog"
                                            type="object"
                                            icon="fa-arrow-left"
                                            class="btn-sm btn-outline-warning"/>
                                </list>
                            </field>
                        </div>
                    </div>

                    <!-- Section Backlog disponible -->
                    <div style="border-radius:10px; border:1px solid #FDE68A; overflow:hidden;">
                        <div style="background:linear-gradient(135deg,#D97706 0%,#F59E0B 100%);
                                    padding:14px 20px; display:flex;
                                    justify-content:space-between; align-items:center;">
                            <div style="display:flex; align-items:center; gap:10px;">
                                <i class="fa fa-list" style="color:white;"/>
                                <span style="font-size:14px; font-weight:700; color:white;">
                                    📦 Product Backlog disponible
                                </span>
                            </div>
                        </div>
                        <div style="background:white; padding:16px;">
                            <field name="backlog_ticket_ids"
                                   nolabel="1"
                                   readonly="1">
                                <list default_order="priority desc"
                                      decoration-danger="priority == '3'"
                                      decoration-warning="priority == '2'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name" string="Tâche"/>
                                    <field name="ticket_type" widget="badge" string="Type"/>
                                    <field name="priority" widget="priority" string="Priorité"/>
                                    <field name="story_points" string="Points"
                                           sum="Total"/>
                                    <field name="assignee_id"
                                           widget="many2one_avatar_user"
                                           string="Assigné"/>
                                    <button name="action_add_to_sprint"
                                            string="+ Sprint"
                                            type="object"
                                            icon="fa-arrow-up"
                                            class="btn-sm btn-outline-primary"/>
                                </list>
                            </field>
                        </div>
                    </div>

                </sheet>
            </form>
        </field>
    </record>
</odoo>