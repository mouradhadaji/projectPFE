<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Main Menu -->
    <menuitem id="menu_jira_root"
              name="Jira PM"
              sequence="10"
              web_icon="jira_project,static/description/gestion.png"/>

    <!-- Dashboard -->
    <menuitem id="menu_jira_dashboard"
              name="Dashboard"
              parent="menu_jira_root"
              action="action_jira_dashboard"
              sequence="5"
              groups="jira_project.group_jira_director"/>

    <!-- Projects -->
    <menuitem id="menu_jira_projects"
              name="Projects"
              parent="menu_jira_root"
              sequence="10"
              groups="jira_project.group_jira_manager"/>

    <menuitem id="menu_jira_project_all"
              name="All Projects"
              parent="menu_jira_projects"
              action="action_jira_project"
              sequence="10"
              groups="jira_project.group_jira_manager"/>

    <menuitem id="menu_jira_new_project"
              name="+ New Project"
              parent="menu_jira_projects"
              action="action_open_new_project_backlog"
              sequence="15"
              groups="jira_project.group_jira_manager"/>

    <menuitem id="menu_jira_backlog"
              name="Product Backlog"
              parent="menu_jira_projects"
              action="action_jira_backlog"
              sequence="20"
              groups="jira_project.group_jira_manager"/>

    <menuitem id="menu_jira_workflow_states"
              name="Workflow States"
              parent="menu_jira_projects"
              action="action_jira_workflow_state"
              sequence="30"
              groups="jira_project.group_jira_director"/>

    <!-- Sprints -->
    <menuitem id="menu_jira_sprints"
              name="Sprints"
              parent="menu_jira_root"
              sequence="20"
              groups="jira_project.group_jira_manager"/>

    <menuitem id="menu_jira_sprint_all"
              name="All Sprints"
              parent="menu_jira_sprints"
              action="action_jira_sprint"
              sequence="10"
              groups="jira_project.group_jira_manager"/>

    <menuitem id="menu_jira_sprint_new"
              name="+ New Sprint"
              parent="menu_jira_sprints"
              action="action_jira_sprint_new"
              sequence="15"
              groups="jira_project.group_jira_manager"/>

    <!-- Tickets -->
    <menuitem id="menu_jira_tickets"
              name="Tickets"
              parent="menu_jira_root"
              sequence="30"/>

    <menuitem id="menu_jira_ticket_all"
              name="All Tickets"
              parent="menu_jira_tickets"
              action="action_jira_ticket_all"
              sequence="10"/>

    <menuitem id="menu_jira_ticket_my"
              name="My Tickets"
              parent="menu_jira_tickets"
              action="action_jira_ticket_my"
              sequence="20"/>

    <!-- Reports -->
    <menuitem id="menu_jira_reports"
              name="Reports"
              parent="menu_jira_root"
              sequence="40"
              groups="jira_project.group_jira_director"/>

    <menuitem id="menu_jira_report_all"
              name="All Reports"
              parent="menu_jira_reports"
              action="action_jira_report"
              sequence="10"
              groups="jira_project.group_jira_director"/>

</odoo>