     <div style="background: white; padding: 20px; border-radius: 8px; margin-top: 20px; box-shadow: 0 1px 6px rgba(0,0,0,0.06);">
    <!-- Header -->
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
        <h3 style="margin:0; color:#333; font-size:15px;">📅 Team Meetings</h3>
        <div id="addMeetingBtn" style="padding:6px 14px; background:#4f8ef7; color:white; border-radius:8px; cursor:pointer; font-size:12px; font-weight:600;">
            + New Meeting
        </div>
    </div>

    <!-- New Meeting  -->
     <div id="meetingForm" style="display:none; background:#f8f9ff; border-radius:8px; padding:16px; margin-bottom:16px; border:1px solid #e0e8ff;">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px;">
            <div>
                <span style="font-size:11px; color:#888; display:block; margin-bottom:4px;">Title *</span>
                <input id="meetingTitle" type="text" placeholder="Meeting title..."
                    style="width:100%; padding:7px 10px; border:1.5px solid #e0e0e0; border-radius:6px; font-size:12px; box-sizing:border-box;"/>
            </div>
            <div>
                <span style="font-size:11px; color:#888; display:block; margin-bottom:4px;">Date &amp; Time *</span>
                <input id="meetingDate" type="datetime-local"
                    style="width:100%; padding:7px 10px; border:1.5px solid #e0e0e0; border-radius:6px; font-size:12px; box-sizing:border-box;"/>
            </div>
            <div>
                <span style="font-size:11px; color:#888; display:block; margin-bottom:4px;">Duration (hours)</span>
                <input id="meetingDuration" type="number" value="1" min="0.5" step="0.5"
                    style="width:100%; padding:7px 10px; border:1.5px solid #e0e0e0; border-radius:6px; font-size:12px; box-sizing:border-box;"/>
            </div>
            <div>
                <span style="font-size:11px; color:#888; display:block; margin-bottom:4px;">Project</span>
                <select id="meetingProject"
                    style="width:100%; padding:7px 10px; border:1.5px solid #e0e0e0; border-radius:6px; font-size:12px; box-sizing:border-box; background:white;">
                    <option value="">— Select project —</option>
                </select>
            </div>
        </div>
        <div style="margin-bottom:12px;">
            <span style="font-size:11px; color:#888; display:block; margin-bottom:4px;">Agenda / Notes</span>
            <textarea id="meetingNotes" rows="2" placeholder="Meeting agenda or notes..."
                style="width:100%; padding:7px 10px; border:1.5px solid #e0e0e0; border-radius:6px; font-size:12px; box-sizing:border-box; resize:vertical;"></textarea>
        </div>
        <div style="margin-bottom:12px;">
            <span style="font-size:11px; color:#888; display:block; margin-bottom:4px;">Participants</span>
            <select id="meetingParticipants" multiple="multiple"
                style="width:100%; padding:7px 10px; border:1.5px solid #e0e0e0; border-radius:6px; font-size:12px; box-sizing:border-box; min-height:80px;">
            </select>
            <span style="font-size:10px; color:#aaa;">Hold Ctrl to select multiple</span>
        </div>


        <div style="display:flex; gap:8px; justify-content:flex-end;">
            <div id="cancelMeetingBtn" style="padding:6px 14px; border:1.5px solid #ddd; border-radius:6px; cursor:pointer; font-size:12px; color:#888;">Cancel</div>
            <div id="saveMeetingBtn" style="padding:6px 14px; background:#4f8ef7; color:white; border-radius:6px; cursor:pointer; font-size:12px; font-weight:600;">Save Meeting</div>
        </div>
    </div>

    <!-- Meetings List -->
    <div id="meetingsList" style="min-height:60px;">
        <div style="color:#bbb; font-size:12px; text-align:center; padding:20px;">Loading meetings...</div>
    </div>
</div>
