    <!-- Dashboard List View -->
    <record id="view_jira_dashboard_list" model="ir.ui.view">
        <field name="name">jira.dashboard.list</field>
        <field name="model">jira.dashboard</field>
        <field name="arch" type="xml">
            <list string="Dashboards">
                <field name="project_id"/>
                <field name="total_tickets"/>
                <field name="completed_tickets"/>
                <field name="in_progress_tickets"/>
                <field name="completion_rate" widget="percentage"/>
            </list>
        </field>
    </record>

    <!-- Dashboard Action -->
    <record id="action_jira_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">jira.dashboard</field>
        <field name="view_mode">form,list</field>
        <field name="target">current</field>
        <field name="context">{}</field>
    </record>

