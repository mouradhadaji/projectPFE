<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sprint List View -->
    <record id="view_jira_sprint_list" model="ir.ui.view">
        <field name="name">jira.sprint.list</field>
        <field name="model">jira.sprint</field>
        <field name="arch" type="xml">
            <list string="Sprints" decoration-bf="state=='active'"
                  decoration-muted="state in ['completed', 'cancelled']">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="duration_days"/>
                <field name="ticket_count"/>
                <field name="progress" widget="progressbar"/>
                <field name="total_story_points"/>
                <field name="completed_story_points"/>
                <field name="state" widget="badge"
                       decoration-info="state=='draft'"
                       decoration-success="state=='active'"
                       decoration-muted="state in ['completed', 'cancelled']"/>
            </list>
        </field>
    </record>
<!-- Sprint Kanban View -->
<record id="view_jira_sprint_kanban" model="ir.ui.view">
    <field name="name">jira.sprint.kanban</field>
    <field name="model">jira.sprint</field>
    <field name="arch" type="xml">
       <kanban highlight_color="color"
        class="o_kanban_dashboard o_kanban_small_column"
        action="%(action_jira_ticket_from_sprint)d"
        type="action"
        sample="1"
        >

            <field name="id"/>
            <field name="name"/>
            <field name="project_id"/>
            <field name="state"/>
            <field name="start_date"/>
            <field name="end_date"/>
            <field name="ticket_count"/>
            <field name="completed_ticket_count"/>
            <field name="progress"/>
            <field name="color"/>
            <field name="total_story_points"/>
            <field name="completed_story_points"/>
            <field name="duration_days"/>

            <templates>
                 <t t-name="kanban-menu">
        <style>
            .o_kanban_view {
                background-color: #f8f9fa !important;
            }
          /* ✅ Espace entre cartes */
    .o_kanban_view .o_kanban_record {
        margin-bottom: 4px !important;
        margin-top: 4px !important;
    }

    .o_kanban_view .o_kanban_group {
        min-width: 220px !important;
        max-width: 220px !important;
    }

    .o_kanban_view .o_kanban_record .o_kanban_card_content {
        padding: 8px !important;
    }
        </style>
    </t>
                <t t-name="kanban-box">
                    <div t-attf-class="oe_kanban_card oe_kanban_global_click oe_kanban_color_#{record.color.raw_value}" style="min-height: 200px; max-width: 350px;">
                        <div class="o_kanban_card_header">
                            <div class="o_kanban_card_header_title">
                                <!-- Icon -->
                                <div class="o_kanban_primary_left" style="margin-bottom: 10px;">
                                    <div t-attf-class="oe_kanban_color_#{record.color.raw_value}" style="width: 70px; height: 70px; display: flex; align-items: center; justify-content: center; border-radius: 4px;">
                                        <i class="fa fa-2x" style="color: white;"
                                           t-attf-class="#{record.state.raw_value === 'active' ? 'fa-rocket' : 'fa-calendar'}"/>
                                    </div>
                                </div>

                                <!-- Sprint Name & Project -->
                                <div class="o_kanban_primary_right">
                                    <h3 class="mb-0" style="font-weight: 600; font-size: 20px;">
                                        <field name="name"/>
                                    </h3>
                                    <div class="text-muted" style="margin-top: 5px;">
                                        <i class="fa fa-folder-o"/> <field name="project_id"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="container o_kanban_card_content" style="margin-top: 15px;">
                            <!-- Dates Row -->
                            <div class="row" style="margin-bottom: 15px;">
                                <div class="col-6" style="padding-right: 5px;">
                                    <div style="font-size: 12px; color: #6c757d; margin-bottom: 3px;">
                                        <i class="fa fa-calendar"/> Start:
                                    </div>
                                    <div style="font-weight: 400;">
                                        <field name="start_date"/>
                                    </div>
                                </div>
                                <div class="col-6" style="padding-left: 5px;">
                                    <div style="font-size: 12px; color: #6c757d; margin-bottom: 3px;">
                                        <i class="fa fa-calendar"/> End:
                                    </div>
                                    <div style="font-weight: 500;">
                                        <field name="end_date"/>
                                    </div>
                                </div>
                            </div>

                            <!-- Progress Bar -->
                            <div style="margin-bottom: 15px;">
                                <div class="d-flex justify-content-between" style="margin-bottom: 5px;">
                                    <small style="color: #6c757d;">Progress</small>
                                    <small style="color: #6c757d;">
                                        <field name="completed_ticket_count"/>/<field name="ticket_count"/> tickets
                                    </small>
                                </div>
                                <field name="progress" widget="progressbar"/>
                            </div>

                            <!-- Stats Row -->
                            <div class="row" style="margin-bottom: 15px;">
                                <div class="col-6">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-ticket fa-2x" style="color: #6c757d; margin-right: 10px;"/>
                                        <div>
                                            <div style="font-size: 24px; font-weight: 600;">
                                                <field name="ticket_count"/>
                                            </div>
                                            <small style="color: #6c757d;">Tickets</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-line-chart fa-2x" style="color: #28a745; margin-right: 10px;"/>
                                        <div>
                                            <div style="font-size: 24px; font-weight: 600;">
                                                <field name="total_story_points"/>
                                            </div>
                                            <small style="color: #6c757d;">Story Points</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Footer Badges -->
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge" style="padding: 5px 12px; border-radius: 12px; font-size: 11px;"
                                      t-attf-style="background-color: #{record.state.raw_value === 'active' ? '#28a745' : record.state.raw_value === 'completed' ? '#17a2b8' : '#6c757d'}; color: white;">
                                    <field name="state"/>
                                </span>
                                <span class="badge bg-light" style="padding: 5px 12px; border-radius: 12px; color: #6c757d; border: 1px solid #dee2e6; font-size: 11px;">
                                    <i class="fa fa-clock-o"/> <field name="duration_days"/> days
                                </span>
                            </div>
                        </div>
                    </div>
                </t>
            </templates>
        </kanban>
    </field>
</record>

    <!-- Sprint Form View -->
    <record id="view_jira_sprint_form" model="ir.ui.view">
        <field name="name">jira.sprint.form</field>
        <field name="model">jira.sprint</field>
        <field name="arch" type="xml">
            <form string="Sprint">
                <header>
                    <button name="action_start_sprint" string="Start Sprint"
                            type="object" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_complete_sprint" string="Complete Sprint"
                            type="object" class="oe_highlight"
                            invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                <button class="oe_stat_button" type="action"
        name="%(action_jira_ticket_from_sprint)d" icon="fa-ticket"
        context="{'default_sprint_id': id, 'search_default_sprint_id': id}">
    <div class="o_field_widget o_stat_info">
        <span class="o_stat_value">
            <field name="completed_ticket_count"/>/<field name="ticket_count"/>
        </span>
        <span class="o_stat_text">Tickets</span>
    </div>
</button>
<button class="oe_stat_button" type="action"
        name="%(action_jira_ticket_from_sprint)d" icon="fa-line-chart"
        context="{'default_sprint_id': id, 'search_default_sprint_id': id}">
    <div class="o_field_widget o_stat_info">
        <span class="o_stat_value">
            <field name="completed_story_points" widget="float"/>/<field name="total_story_points" widget="float"/>
        </span>
        <span class="o_stat_text">Story Points</span>
    </div>
</button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Sprint Name"/>
                        <h1>
                            <field name="name" placeholder="e.g., Sprint 1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" options="{'no_create': True}"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="duration_days"/>
                        </group>
                        <group>
                            <field name="progress" widget="progressbar"/>
                            <field name="sequence"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                    </group>
                    <group string="Sprint Goal">
                        <field name="goal" nolabel="1" placeholder="What is the goal of this sprint?"/>
                    </group>
                    <notebook>
                        <page string="Workflow States" name="workflow">
                            <field name="workflow_state_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"
                                   domain="[('project_id', '=', project_id)]"/>
                        </page>
                        <page string="Tickets" name="tickets">
                            <field name="ticket_ids">
                                <list decoration-muted="state_id.is_closed">
                                    <field name="ticket_number"/>
                                    <field name="name"/>
                                    <field name="ticket_type" widget="badge"/>
                                    <field name="priority" widget="priority"/>
                                    <field name="assignee_id" widget="many2one_avatar_user"/>
                                    <field name="state_id"/>
                                    <field name="story_points"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Sprint Search View -->
    <record id="view_jira_sprint_search" model="ir.ui.view">
        <field name="name">jira.sprint.search</field>
        <field name="model">jira.sprint</field>
        <field name="arch" type="xml">
            <search string="Sprints">
                <field name="name"/>
                <field name="project_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="project" context="{'group_by': 'project_id'}"/>
                    <filter string="Status" name="status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>


<!-- Sprint Action -->
<record id="action_jira_sprint" model="ir.actions.act_window">
    <field name="name">Sprints</field>
    <field name="res_model">jira.sprint</field>
    <field name="view_mode">kanban,list,form</field>
    <field name="domain">[]</field>
    <field name="context">{
        'search_default_active': 1,
        'kanban_view_ref': 'jira_project.view_jira_sprint_kanban'
    }</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            Create your first sprint
        </p>
        <p>
            Sprints are time-boxed periods where teams complete work.
        </p>
    </field>
</record>


    <!-- Active Sprints Action -->
    <record id="action_jira_sprint_active" model="ir.actions.act_window">
        <field name="name">Active Sprints</field>
        <field name="res_model">jira.sprint</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>