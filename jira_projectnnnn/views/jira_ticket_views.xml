<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ticket List View -->
    <record id="view_jira_ticket_list" model="ir.ui.view">
        <field name="name">jira.ticket.list</field>
        <field name="model">jira.ticket</field>
        <field name="arch" type="xml">
            <list string="Tickets"
                  decoration-danger="is_overdue==True"
                  decoration-muted="state_id.is_closed==True">
                <field name="ticket_number"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="sprint_id"/>
                <field name="ticket_type" widget="badge"/>
                <field name="priority" widget="priority"/>
                <field name="assignee_id" widget="many2one_avatar_user"/>
                <field name="state_id"/>
                <field name="story_points" groups="jira_project.group_jira_manager"/>
                <field name="due_date"/>
                <field name="is_overdue" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Ticket Form View -->
    <record id="view_jira_ticket_form" model="ir.ui.view">
        <field name="name">jira.ticket.form</field>
        <field name="model">jira.ticket</field>
        <field name="arch" type="xml">
            <form string="Ticket">
              <header>
                 <button name="unlink" string="Supprimer"
                      type="object" class="btn-danger"
                     groups="jira_project.group_jira_director"/>
             </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_subtasks" icon="fa-tasks"
                                invisible="subtask_count == 0">
                            <field string="Subtasks" name="subtask_count" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-paperclip"
                                invisible="attachment_count == 0">
                            <field string="Attachments" name="attachment_count" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="ticket_number" class="oe_edit_only"/>
                        <h1>
                            <field name="ticket_number" readonly="1" class="oe_inline"/>
                        </h1>
                        <label for="name" string="Summary"/>
                        <h2>
                            <field name="name" placeholder="Brief description of the issue..."/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" options="{'no_create': True}"/>
                            <field name="sprint_id"
                                   domain="[('project_id', '=', project_id)]"
                                   options="{'no_create': True}"
                                   groups="jira_project.group_jira_manager"/>
                            <field name="ticket_type"/>
                            <field name="epic_id"
                                   domain="[('ticket_type', '=', 'epic'), ('project_id', '=', project_id)]"
                                   invisible="ticket_type == 'epic'"/>
                            <field name="parent_id"
                                   domain="[('ticket_type', '!=', 'subtask'), ('project_id', '=', project_id)]"
                                   invisible="ticket_type != 'subtask'"/>
                        </group>
                        <group>
                            <field name="priority" widget="priority"/>
                            <field name="assignee_id" widget="many2one_avatar_user"/>
                            <field name="reporter_id" widget="many2one_avatar_user"/>
                            <field name="due_date"/>
                            <field name="kanban_state" widget="state_selection"/>
                            <field name="state_id" domain="[('project_id', '=', project_id)]"/>
                            <field name="ticket_status"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Detailed description..."/>
                        </page>
                        <page string="Details" name="details">
                            <group>
                                <group string="Estimation">
                                   <field name="story_points" groups="jira_project.group_jira_manager"/>
                                    <field name="original_estimate"/>
                                    <field name="remaining_estimate"/>
                                    <field name="time_spent"/>
                                </group>
                                <group string="Classification">
                                    <field name="label_ids" widget="many2many_tags"/>
                                    <field name="component_ids" widget="many2many_tags"/>
                                </group>
                            </group>
                        </page>
                        <page string="Sub-tasks" name="subtasks" invisible="ticket_type == 'subtask'">
                            <field name="subtask_ids">
                                <list>
                                    <field name="ticket_number"/>
                                    <field name="name"/>
                                    <field name="assignee_id" widget="many2one_avatar_user"/>
                                    <field name="state_id"/>
                                    <field name="story_points" groups="jira_project.group_jira_manager"/>
                                </list>
                            </field>
                        </page>
                        <page string="Linked Issues" name="links">
                            <group>
                                <field name="blocked_by_ids" widget="many2many_tags"/>
                                <field name="blocks_ids" widget="many2many_tags"/>
                                <field name="related_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                        <page string="Attachments" name="attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_jira_ticket_kanban_status" model="ir.ui.view">
        <field name="name">jira.ticket.kanban.status</field>
        <field name="model">jira.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="ticket_status"
                    class="o_kanban_small_column o_ticket_kanban"
                    quick_create="false"
                    group_create="false"
                    group_delete="false"
                    group_edit="false"
                    records_draggable="true">
                <field name="id"/>
                <field name="name"/>
                <field name="ticket_number"/>
                <field name="ticket_status"/>
                <field name="priority"/>
                <field name="assignee_id"/>
                <field name="project_id"/>
                <field name="ticket_type"/>
                <field name="story_points"/>

                <progressbar field="ticket_status"
                            colors='{"draft": "muted", "in_progress": "warning", "done": "success", "complete": "info"}'
                            sum_field="story_points"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="o_ticket_card">
                            <!-- HEADER -->
                            <div style="background-color: #FAD9AF; padding: 10px 14px; border-radius: 12px 12px 0 0;">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <strong style="color: #5a3e00; font-size: 13px;">
                                        <field name="ticket_number"/>
                                    </strong>
                                    <field name="priority" widget="priority"/>
                                </div>
                                <div style="color: #7a5200; font-size: 13px; margin-top: 4px; font-weight: 500;">
                                    <field name="name"/>
                                </div>
                            </div>
                            <!-- CONTENU -->
                            <div style="padding: 10px 14px; background: white;">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                    <field name="ticket_type" widget="badge"/>
                                    <small style="color: #6c757d;"><field name="project_id"/></small>
                                </div>
                                <div t-if="record.story_points.raw_value" style="color: #6c757d; font-size: 12px;">
                                    <i class="fa fa-star"/> <field name="story_points"/> pts
                                </div>
                            </div>
                            <!-- FOOTER -->
                            <div style="background-color: #FAD9AF; padding: 8px 14px; border-radius: 0 0 12px 12px; display: flex; justify-content: space-between; align-items: center;">
                                <field name="activity_ids" widget="kanban_activity"/>
                                <field name="assignee_id" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Ticket Search View -->
    <record id="view_jira_ticket_search" model="ir.ui.view">
        <field name="name">jira.ticket.search</field>
        <field name="model">jira.ticket</field>
        <field name="arch" type="xml">
            <search string="Tickets">
                <field name="ticket_number"/>
                <field name="name"/>
                <field name="sprint_id"/>
                <field name="project_id"/>
                <filter string="Draft" name="filter_draft"
                        domain="[('state_id.name', 'ilike', 'draft')]"/>
                <filter string="Active" name="filter_active"
                        domain="[('state_id.is_closed', '=', False)]"/>
                <filter string="Complete" name="filter_complete"
                        domain="[('state_id.is_closed', '=', True)]"/>
                <filter string="Cancelled" name="filter_cancelled"
                        domain="[('state_id.name', 'ilike', 'cancel')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Sprint" name="group_sprint" context="{'group_by': 'sprint_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'state_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Ticket Action -->
    <record id="action_jira_ticket" model="ir.actions.act_window">
        <field name="name">Tickets</field>
        <field name="res_model">jira.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first ticket</p>
        </field>
    </record>

    <!-- Lier kanban view à action_jira_ticket -->
    <record id="action_jira_ticket_kanban_view" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="action_jira_ticket"/>
        <field name="view_id" ref="view_jira_ticket_kanban_status"/>
        <field name="view_mode">kanban</field>
        <field name="sequence">1</field>
    </record>

    <!-- My Tickets Action -->
    <record id="action_jira_ticket_my" model="ir.actions.act_window">
        <field name="name">My Tickets</field>
        <field name="res_model">jira.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('assignee_id', '=', uid)]</field>
        <field name="context">{'group_by': 'ticket_status'}</field>
    </record>

    <record id="action_jira_ticket_my_kanban_view" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="action_jira_ticket_my"/>
        <field name="view_id" ref="view_jira_ticket_kanban_status"/>
        <field name="view_mode">kanban</field>
        <field name="sequence">1</field>
    </record>

    <!-- Sprint Tickets Action -->
    <record id="action_jira_ticket_from_sprint" model="ir.actions.act_window">
        <field name="name">Sprint Tickets</field>
        <field name="res_model">jira.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('sprint_id', '=', active_id)]</field>
        <field name="context">{
            'default_sprint_id': active_id,
            'group_by': 'ticket_status',
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No tickets in this sprint yet</p>
        </field>
    </record>

    <record id="action_jira_ticket_from_sprint_kanban" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="action_jira_ticket_from_sprint"/>
        <field name="view_id" ref="view_jira_ticket_kanban_status"/>
        <field name="view_mode">kanban</field>
        <field name="sequence">1</field>
    </record>

    <!-- All Tickets Action -->
    <record id="action_jira_ticket_all" model="ir.actions.act_window">
        <field name="name">All Tickets</field>
        <field name="res_model">jira.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'group_by': 'ticket_status'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first ticket</p>
        </field>
    </record>

    <record id="action_jira_ticket_all_kanban" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="action_jira_ticket_all"/>
        <field name="view_id" ref="view_jira_ticket_kanban_status"/>
        <field name="view_mode">kanban</field>
        <field name="sequence">1</field>
    </record>

    <!-- Labels -->
    <record id="view_jira_label_list" model="ir.ui.view">
        <field name="name">jira.label.list</field>
        <field name="model">jira.label</field>
        <field name="arch" type="xml">
            <list string="Labels" editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_jira_label" model="ir.actions.act_window">
        <field name="name">Labels</field>
        <field name="res_model">jira.label</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Components -->
    <record id="view_jira_component_list" model="ir.ui.view">
        <field name="name">jira.component.list</field>
        <field name="model">jira.component</field>
        <field name="arch" type="xml">
            <list string="Components" editable="bottom">
                <field name="name"/>
                <field name="lead_id" widget="many2one_avatar_user"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="action_jira_component" model="ir.actions.act_window">
        <field name="name">Components</field>
        <field name="res_model">jira.component</field>
        <field name="view_mode">list</field>
    </record>

</odoo>