<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_jira_sprint_report" model="ir.actions.report">
        <field name="name">Sprint Report</field>
        <field name="model">jira.sprint</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">jira_project.report_sprint_template</field>
        <field name="report_file">jira_project.report_sprint_template</field>
        <field name="binding_model_id" ref="model_jira_sprint"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_sprint_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="sprint">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- Header -->
                        <div style="background: #0D1B2A; padding: 20px;
                                    border-radius: 8px; margin-bottom: 20px;">
                            <h1 style="color: #1FC7DE; margin: 0;">
                                🚀 Sprint Report
                            </h1>
                            <p style="color: white; margin: 5px 0 0;">
                                <t t-esc="sprint.name"/> —
                                <t t-esc="sprint.project_id.name"/>
                            </p>
                        </div>

                        <!-- Infos Sprint -->
                        <div class="row" style="margin-bottom: 20px;">
                            <div class="col-6">
                                <table class="table table-bordered">
                                    <tr>
                                        <th>Start Date</th>
                                        <td><t t-esc="sprint.start_date"/></td>
                                    </tr>
                                    <tr>
                                        <th>End Date</th>
                                        <td><t t-esc="sprint.end_date"/></td>
                                    </tr>
                                    <tr>
                                        <th>Status</th>
                                        <td><t t-esc="sprint.state"/></td>
                                    </tr>
                                    <tr>
                                        <th>Progress</th>
                                        <td><t t-esc="sprint.progress"/>%</td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-bordered">
                                    <tr>
                                        <th>Total Tickets</th>
                                        <td><t t-esc="sprint.ticket_count"/></td>
                                    </tr>
                                    <tr>
                                        <th>Total Story Points</th>
                                        <td><t t-esc="sprint.total_story_points"/></td>
                                    </tr>
                                    <tr>
                                        <th>Completed Points</th>
                                        <td><t t-esc="sprint.completed_story_points"/></td>
                                    </tr>
                                    <tr>
                                        <th>Duration</th>
                                        <td><t t-esc="sprint.duration_days"/> days</td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Liste des Tickets -->
                        <h3>Tickets</h3>
                        <table class="table table-striped table-bordered">
                            <thead style="background: #185FA5; color: white;">
                                <tr>
                                    <th>#</th>
                                    <th>Name</th>
                                    <th>Type</th>
                                    <th>Priority</th>
                                    <th>Status</th>
                                    <th>Story Points</th>
                                    <th>Assignee</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="sprint.ticket_ids" t-as="ticket">
                                    <tr>
                                        <td><t t-esc="ticket.ticket_number"/></td>
                                        <td><t t-esc="ticket.name"/></td>
                                        <td><t t-esc="ticket.ticket_type"/></td>
                                        <td><t t-esc="ticket.priority"/></td>
                                        <td><t t-esc="ticket.ticket_status"/></td>
                                        <td><t t-esc="ticket.story_points"/></td>
                                        <td><t t-esc="ticket.assignee_id.name"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>