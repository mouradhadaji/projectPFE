<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_jira" model="ir.module.category">
        <field name="name">Jira PM</field>
        <field name="sequence">20</field>
        <field name="exclusive">True</field>
    </record>

    <record id="group_jira_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_jira"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_jira_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_jira"/>

    </record>

    <record id="group_jira_director" model="res.groups">
        <field name="name">Director</field>
        <field name="category_id" ref="module_category_jira"/>
        <field name="implied_ids" eval="[(4, ref('group_jira_manager'))]"/>
    </record>
</odoo>